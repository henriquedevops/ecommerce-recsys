# Copie para .env e ajuste conforme o ambiente. O .env NUNCA vai para o git.
# Todas as variáveis são opcionais — sem .env, valem os defaults do config.py.
# Hiperparâmetros de experimento NÃO ficam aqui: ver params.yaml (rastreado pelo DVC).

DATA_DIR=data
MODELS_DIR=models
REPORTS_DIR=reports
# Vazio (ou ausente) = MLflow grava em ./mlruns local; aponte para um server se houver:
# MLFLOW_TRACKING_URI=http://localhost:5000
RANDOM_SEED=42
